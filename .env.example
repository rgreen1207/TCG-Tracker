# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8888

# ── Security ──────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_32_byte_hex_string
ADMIN_PASSWORD=change_me_to_a_strong_password
JWT_EXPIRE_HOURS=24

# ── Pushover (push notifications) ─────────────────────────
# Sign up free at https://pushover.net
# Create an app token at https://pushover.net/apps/build
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_API_TOKEN=your_pushover_app_token

# ── eBay Browse API ───────────────────────────────────────
# Register at https://developer.ebay.com → create app → get Client ID + Secret
EBAY_APP_ID=your_ebay_app_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# ── PriceCharting ─────────────────────────────────────────
# Free key at https://www.pricecharting.com/api
PRICECHARTING_API_KEY=your_pricecharting_api_key

# ── Pokemon TCG API ───────────────────────────────────────
# Free key at https://pokemontcg.io (higher rate limits with key)
POKEMONTCG_API_KEY=your_pokemontcg_api_key

# ── Polling ───────────────────────────────────────────────
POLL_INTERVAL_SECONDS=21600
NOTIFY_COOLDOWN_HOURS=12

# ── Filters ───────────────────────────────────────────────
EXCLUDED_SELLER_COUNTRIES=["CN","HK"]
